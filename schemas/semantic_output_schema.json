{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Semantic Output Schema",
  "description": "Module B 输出给 Module C 的个性化语义理解结果",
  "type": "object",
  "required": ["schema_version", "video_id", "status", "input_sign_sequence", "normalized_text", "inferred_intent", "overall_confidence"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "video_id": { "type": "string" },
    "user_id": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["ok", "timeout", "error"] },
    "input_sign_sequence": { "type": "array", "items": { "type": "string" } },
    "rag_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "score": { "type": "number" },
          "domain": { "type": "string" }
        }
      }
    },
    "memory_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "score": { "type": "number" },
          "meaning": { "type": "string" }
        }
      }
    },
    "emotion": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "score": { "type": "number" }
      }
    },
    "normalized_text": { "type": "string" },
    "inferred_intent": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "confidence_breakdown": {
      "type": "object",
      "properties": {
        "sign_conf": { "type": "number" },
        "rag_conf": { "type": "number" },
        "memory_conf": { "type": "number" },
        "llm_conf": { "type": "number" }
      }
    },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "error": { "type": ["object", "null"] }
  }
}
