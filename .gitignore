# ==================================================
# PCS-SignAI Project Git Ignore
# ==================================================


# ==================================================
# Frontend: React / Vite
# ==================================================

frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# Frontend environment
frontend/.env
frontend/.env.*
!frontend/.env.example


# ==================================================
# Python
# ==================================================

# Cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Test / analysis cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/


# Virtual environments
.venv/
**/.venv/
venv/
env/
ENV/


# ==================================================
# Runtime generated files
# ==================================================

# Uploaded user videos
uploads/
**/uploads/

# Inference outputs
outputs/
**/outputs/

# Runtime logs
logs/
**/logs/


# Temporary generated files
*.tmp
*.temp
*.swp
*.swo
*~


# ==================================================
# Machine Learning Generated Files
# ==================================================

# Model cache
*.pt
*.pth
*.ckpt
*.onnx

# HuggingFace cache
.cache/
huggingface/


# ==================================================
# IDE / Editor
# ==================================================

.vscode/
.idea/
*.code-workspace


# ==================================================
# Operating System
# ==================================================

.DS_Store
Thumbs.db
desktop.ini


# ==================================================
# Local Environment / Secrets
# ==================================================

.env
.env.*
!.env.example


# ==================================================
# Node
# ==================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*



# ==================================================
# Media / Demo Runtime Data
# ==================================================

# User uploaded videos
*.mp4
*.avi
*.mov

# Generated json results
sign_output.json
semantic_output.json


